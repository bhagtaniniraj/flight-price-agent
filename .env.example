# Amadeus API (Free at https://developers.amadeus.com)
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Kiwi/Tequila API (Free at https://tequila.kiwi.com)
KIWI_API_KEY=your_kiwi_api_key
KIWI_BASE_URL=https://api.tequila.kiwi.com

# Duffel API (Free at https://duffel.com)
DUFFEL_API_TOKEN=your_duffel_token
DUFFEL_BASE_URL=https://api.duffel.com

# Skyscanner API (Apply at https://partners.skyscanner.net) - Optional for comparison
SKYSCANNER_API_KEY=your_skyscanner_api_key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
